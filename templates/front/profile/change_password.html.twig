{% extends 'base.html.twig' %}

{% block title %}Changer mon mot de passe - CESIZen{% endblock %}

{% block body %}
<div class="py-8 md:py-12 max-w-3xl mx-auto px-4 animate-fade-in">
    
    <div class="mb-8">
        <a href="{{ path('app_profile_index') }}" class="btn btn-ghost btn-sm pl-0 hover:bg-transparent text-primary focus-visible:ring-2 focus-visible:ring-info outline-none mb-2 hover:underline">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Retour à mon profil
        </a>
        <h1 class="text-3xl md:text-4xl font-extrabold text-dsfr-blue tracking-tight">Sécurité</h1>
        <p class="text-base-content/70 mt-2 font-medium">Modifier le mot de passe de votre compte.</p>
    </div>

    <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm">
        <div class="card-body p-6 md:p-8">
            
            {{ form_start(passwordForm, {'attr': {'class': 'space-y-6'}}) }}
                
                <div class="bg-base-200/50 p-4 rounded-sm border border-base-200 mb-6">
                    <p class="text-sm text-base-content/80 font-medium mb-4">Pour des raisons de sécurité, veuillez confirmer votre mot de passe actuel avant d'en définir un nouveau.</p>
                    <div class="form-control w-full">
                        {{ form_label(passwordForm.oldPassword, null, {'label_attr': {'class': 'label pb-1 cursor-pointer font-bold text-dsfr-blue'}}) }}
                        {{ form_widget(passwordForm.oldPassword) }}
                        <div class="text-sm text-error mt-1 font-medium">{{ form_errors(passwordForm.oldPassword) }}</div>
                    </div>
                </div>

                <div class="form-control w-full relative">
                    {{ form_label(passwordForm.plainPassword.first, null, {'label_attr': {'class': 'label pb-1 cursor-pointer font-bold'}}) }}
                    {{ form_widget(passwordForm.plainPassword.first) }}
                    <div class="text-sm text-error mt-1 font-medium">{{ form_errors(passwordForm.plainPassword.first) }}</div>
                </div>

                <div class="form-control w-full">
                    {{ form_label(passwordForm.plainPassword.second, null, {'label_attr': {'class': 'label pb-1 cursor-pointer font-bold'}}) }}
                    {{ form_widget(passwordForm.plainPassword.second) }}
                    <div class="text-sm text-error mt-1 font-medium">{{ form_errors(passwordForm.plainPassword.second) }}</div>
                </div>

                <div class="mt-8 pt-6 border-t border-base-200 flex flex-col-reverse sm:flex-row gap-3 justify-end items-center">
                    <a href="{{ path('app_profile_index') }}" class="btn btn-ghost w-full sm:w-auto font-medium">Annuler</a>
                    <button type="submit" class="btn btn-primary bg-[#003189] hover:bg-[#002366] text-white border-none w-full sm:w-auto px-8">Mettre à jour le mot de passe</button>
                </div>
                
            {{ form_end(passwordForm) }}
            
        </div>
    </div>
</div>
{% endblock %}
