{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h1 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue tracking-tight">Gestion des Utilisateurs</h1>
        
        {# Formulaire de recherche #}
        <form method="get" class="flex w-full md:w-auto join">
            <input type="text" name="q" value="{{ search_query }}" placeholder="Rechercher (nom, email)..." 
                   class="input input-sm input-bordered join-item focus:outline-none focus:border-dsfr-blue focus:ring-1 focus:ring-dsfr-blue w-full md:w-64 rounded-sm"
                   aria-label="Recherche utilisateur">
                   
            {{ include('components/_button.html.twig', {
                label: 'Rechercher',
                variant: 'primary',
                size: 'sm',
                extra_classes: 'join-item rounded-r-sm',
                type: 'submit'
            }) }}
            
            {% if search_query %}
                <a href="{{ path('app_admin_user_index') }}" class="btn btn-sm btn-square btn-ghost join-item rounded-sm text-base-content/60 hover:text-dsfr-red" aria-label="Effacer la recherche" title="Effacer">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </a>
            {% endif %}
        </form>
    </div>

    <div class="overflow-x-auto rounded-sm border border-base-200">
        <table class="table table-zebra table-sm md:table-md w-full">
            <thead class="bg-base-200 text-base-content">
                <tr>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Utilisateur</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Inscription</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Statut</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Rôle</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in pagination %}
                    <tr class="hover">
                        <td>
                            <div class="flex flex-col">
                                <span class="font-bold text-base-content">{{ user.name }}</span>
                                <span class="text-sm text-base-content/70">{{ user.email }}</span>
                            </div>
                        </td>
                        <td class="text-sm text-base-content/80 font-medium">
                            {{ user.creationDate|date('d/m/Y') }}
                        </td>
                        <td>
                            {% if user.isActive %}
                                {{ include('components/_badge.html.twig', { label: 'Actif', variant: 'success', rounded: true }) }}
                            {% else %}
                                {{ include('components/_badge.html.twig', { label: 'Inactif', variant: 'error', rounded: true }) }}
                            {% endif %}
                            
                            {% if user.lockedUntil and user.lockedUntil > date() %}
                                <div class="mt-1">
                                    {{ include('components/_badge.html.twig', { label: 'Verrouillé', variant: 'warning', rounded: true }) }}
                                </div>
                            {% endif %}
                        </td>
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="text-dsfr-purple font-bold text-sm">Administrateur</span>
                            {% else %}
                                <span class="text-base-content/80 text-sm font-medium">Utilisateur</span>
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <div class="flex justify-end gap-2">
                                {# Toggle Active #}
                                {% if app.user != user %}
                                    <form method="post" action="{{ path('app_admin_user_toggle_active', {'id': user.id}) }}" class="inline-block" onsubmit="return confirm('Êtes-vous sûr de vouloir {% if user.isActive %}désactiver{% else %}activer{% endif %} ce compte ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_active' ~ user.id) }}">
                                        <button type="submit" class="btn btn-xs rounded-sm {% if user.isActive %}btn-error btn-outline{% else %}btn-success btn-outline{% endif %}" title="{% if user.isActive %}Désactiver{% else %}Activer{% endif %}">
                                            {% if user.isActive %}Désactiver{% else %}Activer{% endif %}
                                        </button>
                                    </form>
                                
                                    {# Toggle Admin Role #}
                                    <form method="post" action="{{ path('app_admin_user_toggle_role', {'id': user.id}) }}" class="inline-block" onsubmit="return confirm('Êtes-vous sûr de vouloir {% if 'ROLE_ADMIN' in user.roles %}retirer les droits administrateur de{% else %}promouvoir administrateur{% endif %} cet utilisateur ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_role' ~ user.id) }}">
                                        <button type="submit" class="btn btn-xs rounded-sm {% if 'ROLE_ADMIN' in user.roles %}btn-ghost border border-base-300 text-base-content/70 hover:bg-base-300{% else %}bg-purple-100 text-purple-700 hover:bg-purple-200 border-none{% endif %}" title="{% if 'ROLE_ADMIN' in user.roles %}Retirer Admin{% else %}Rendre Admin{% endif %}">
                                            {% if 'ROLE_ADMIN' in user.roles %}Rétrograder{% else %}Promouvoir{% endif %}
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="py-12 text-center text-base-content/60 font-medium">
                            Aucun utilisateur trouvé.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination KnpPaginatorBundle #}
    {% if pagination.getTotalItemCount > 0 %}
        <div class="mt-6 flex justify-center">
            {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
        </div>
    {% endif %}
{% endblock %}
