{% extends 'base.html.twig' %}

{% block title %}Questionnaire en cours - CESIZen{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
        <a href="{{ path('app_diagnostic_index') }}" class="text-green-700 hover:text-green-800 transition-colors inline-flex items-center font-medium">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Retour
        </a>
    </div>

    <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100">
        <div class="bg-gray-50 border-b border-gray-200 px-6 py-6 md:px-10">
            <h1 class="text-2xl font-bold text-gray-900">{{ quiz.title }}</h1>
            <p class="text-gray-600 mt-2">Cochez les événements qui vous sont arrivés au cours des 12 derniers mois.</p>
        </div>

        <form action="{{ path('app_diagnostic_take', {'id': quiz.id}) }}" method="post" class="divide-y divide-gray-100">
            
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="bg-{{ label == 'error' ? 'red' : 'green' }}-50 border-l-4 border-{{ label == 'error' ? 'red' : 'green' }}-500 p-4 m-6 rounded">
                        <p class="text-{{ label == 'error' ? 'red' : 'green' }}-700">{{ message }}</p>
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="p-6 md:p-10 space-y-4">
                {% for question in questions %}
                    {% if question.isActive %}
                        <div class="flex items-start bg-gray-50 rounded-lg p-4 transition-colors hover:bg-green-50 focus-within:ring-2 focus-within:ring-green-500 focus-within:bg-green-50 border border-transparent hover:border-green-100">
                            {% for response in question.responses %}
                                {% if response.isActive %}
                                    <div class="flex items-center h-5 mt-0.5">
                                        <input id="response_{{ response.id }}" name="responses[]" value="{{ response.id }}" type="checkbox" class="focus:ring-green-500 h-5 w-5 text-green-600 border-gray-300 rounded cursor-pointer">
                                    </div>
                                    <div class="ml-3 text-sm flex-grow">
                                        <label for="response_{{ response.id }}" class="font-medium text-gray-800 cursor-pointer block text-base">{{ question.title }}</label>
                                        {% if question.description %}
                                            <p class="text-gray-500 cursor-pointer">{{ question.description }}</p>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                {% else %}
                    <p class="text-gray-500 text-center py-8">Aucune question n'est configurée pour ce test.</p>
                {% endfor %}
            </div>
            
            <div class="px-6 py-8 md:px-10 bg-gray-50 sm:flex sm:flex-row-reverse border-t border-gray-200">
                <button type="submit" class="w-full inline-flex justify-center rounded-full border border-transparent shadow-md px-8 py-4 bg-green-700 text-base font-bold text-white hover:bg-green-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 sm:ml-3 sm:w-auto transform hover:-translate-y-0.5 transition-all">
                    Calculer mon score
                </button>
                <div class="mt-4 sm:mt-0 flex items-center justify-center sm:justify-start">
                    <p class="text-sm text-gray-500">Vos réponses sont confidentielles.</p>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}
