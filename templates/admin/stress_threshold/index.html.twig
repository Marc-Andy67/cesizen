{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
        <div>
            <h1 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue tracking-tight">Configuration des Seuils de Stress</h1>
            <p class="text-base-content/70 mt-2 font-medium">Définit les paliers de stress et les recommandations qui s'afficheront après le questionnaire de Holmes & Rahe.</p>
        </div>
        
        {{ include('components/_button.html.twig', {
            label: 'Nouveau Seuil',
            variant: 'primary',
            attr: 'href="' ~ path('app_admin_stress_threshold_new') ~ '"',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>'
        }) }}
    </div>

    <div class="overflow-x-auto rounded-sm border border-base-200">
        <table class="table table-zebra table-sm md:table-md w-full">
            <thead class="bg-base-200 text-base-content">
                <tr>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Nom public</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Score Min</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Score Max</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Recommandation</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for item in pagination %}
                    <tr class="hover">
                        <td>
                            <span class="font-bold text-base-content">{{ item.name }}</span>
                            <span class="text-xs text-base-content/60 block font-medium">{{ item.level }}</span>
                        </td>
                        <td>
                            <span class="font-extrabold text-dsfr-blue">{{ item.minScore }}</span>
                        </td>
                        <td>
                            <span class="font-extrabold text-dsfr-blue">{{ item.maxScore|default('∞') }}</span>
                        </td>
                        <td>
                            <span class="text-sm text-base-content/80 block w-64 truncate">{{ item.advice }}</span>
                        </td>
                        <td class="text-right">
                            <div class="flex justify-end gap-2 items-center">
                                {% if item.quizzes|length > 0 %}
                                    <span class="text-xs text-base-content/60 mr-2">Lié à {{ item.quizzes|length }} quiz</span>
                                {% else %}
                                    <form action="{{ path('app_admin_stress_threshold_delete', {id: item.id}) }}" method="post" data-turbo="false" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                        <button type="submit" class="btn btn-xs btn-error rounded-sm text-white">Supprimer</button>
                                    </form>
                                {% endif %}
                                <a href="{{ path('app_admin_stress_threshold_edit', {'id': item.id}) }}" class="btn btn-xs rounded-sm btn-ghost border border-base-300 text-dsfr-blue font-medium">Éditer</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="py-12 text-center text-base-content/60 font-medium">
                            Aucun seuil configuré. Veuillez exécuter les fixtures.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.getTotalItemCount > 0 %}
        <div class="mt-6 flex justify-center">
            {{ knp_pagination_render(pagination, 'components/_knp_pagination.html.twig') }}
        </div>
    {% endif %}
{% endblock %}
