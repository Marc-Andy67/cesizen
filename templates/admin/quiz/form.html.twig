{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="mb-6 flex justify-between items-center">
        <h1 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue tracking-tight">
            {{ quiz.id ? 'Éditer le' : 'Nouveau' }} Questionnaire
        </h1>
        <a href="{{ path('app_admin_quiz_index') }}" class="btn btn-ghost rounded-sm border border-base-300">
            Retour à la liste
        </a>
    </div>

    {{ form_start(form, {'attr': {'id': 'quiz_main_form', 'class': 'space-y-8'}}) }}

        {# SECTION 1: Informations Générales #}
        <div class="card bg-white shadow-sm border border-base-200 rounded-sm">
            <div class="card-body p-6 md:p-8">
                <h2 class="card-title text-xl text-base-content border-b border-base-200 pb-2 mb-6 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-dsfr-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Informations Générales
                </h2>
                
                <div class="space-y-6">
                    {# Champ title #}
                    <div>
                        {{ form_label(form.title, 'Titre', {'label_attr': {'class': 'label text-sm font-bold text-base-content/80 uppercase tracking-wider mb-1'}}) }}
                        {{ form_widget(form.title, {'attr': {'class': 'input input-bordered w-full rounded-sm focus:border-dsfr-blue', 'placeholder': 'Ex: Échelle de stress Holmes & Rahe'}}) }}
                        <div class="text-xs text-base-content/50 mt-1">Nom affiché aux utilisateurs sur la page de diagnostic</div>
                        <div class="text-error text-sm mt-1">{{ form_errors(form.title) }}</div>
                    </div>

                    {# Champ description #}
                    <div>
                        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'label text-sm font-bold text-base-content/80 uppercase tracking-wider mb-1'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'textarea textarea-bordered w-full rounded-sm min-h-24 focus:border-dsfr-blue', 'placeholder': 'Décrivez l\'objectif de ce questionnaire...'}}) }}
                        <div class="text-xs text-base-content/50 mt-1">Résumé affiché dans la card de présentation du quiz</div>
                        <div class="text-error text-sm mt-1">{{ form_errors(form.description) }}</div>
                    </div>

                    {# Champ categories #}
                    <div>
                        {{ form_label(form.categories, 'Catégories', {'label_attr': {'class': 'label text-sm font-bold text-base-content/80 uppercase tracking-wider mb-1'}}) }}
                        <div class="border border-base-300 rounded-sm p-4 bg-base-50">
                            {{ form_widget(form.categories, {'attr': {'class': 'flex flex-wrap gap-4'}}) }}
                        </div>
                        <div class="text-xs text-base-content/50 mt-1">Permet de filtrer et classer le questionnaire</div>
                        <div class="text-error text-sm mt-1">{{ form_errors(form.categories) }}</div>
                    </div>

                    {# Champ isActive #}
                    <div class="flex items-center justify-between bg-base-200 rounded-sm p-4 border border-base-300">
                        <div>
                            <p class="font-bold text-sm">Questionnaire actif</p>
                            <p class="text-xs text-base-content/60">
                                Les utilisateurs peuvent accéder à ce questionnaire
                            </p>
                        </div>
                        {{ form_widget(form.isActive, {'attr': {'class': 'toggle toggle-primary'}}) }}
                    </div>
                </div>
            </div>
        </div>

        {# Hidden select to keep questions mapped for main form submit #}
        <div class="hidden">
            {{ form_widget(form.questions) }}
        </div>
    {{ form_end(form) }}

        {% if quiz.id %}
            {# SECTION 2: Questions associées #}
            <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm">
                <div class="card-body">
                    <div class="flex justify-between items-center border-b border-base-200 pb-2 mb-4">
                        <h2 class="card-title text-xl text-base-content m-0">Questions Associées</h2>
                        <button type="button" class="btn btn-sm btn-primary rounded-sm" onclick="questions_modal.showModal()">
                            + Associer une question
                        </button>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {% for question in quiz.questions %}
                        <div class="card bg-base-200 p-4 rounded-sm border border-base-300">
                            <div class="flex justify-between items-start">
                                <div>
                                    <span class="badge badge-neutral mb-2">Question {{ loop.index }}</span>
                                    <h3 class="font-bold text-base-content">{{ question.title }}</h3>
                                </div>
                                <form action="{{ path('app_admin_quiz_detach_question', {id: quiz.id, questionId: question.id}) }}" method="post" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('detach_question' ~ quiz.id) }}">
                                    <button type="submit" class="btn btn-xs btn-error btn-outline rounded-sm">Retirer</button>
                                </form>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-sm text-base-content/60">Aucune question associée.</p>
                    {% endfor %}
                    </div>
                </div>
            </div>

            {# SECTION 3: Seuils de résultats #}
            <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm mb-8">
                <div class="card-body">
                    <div class="flex justify-between items-center border-b border-base-200 pb-2 mb-4">
                        <h2 class="card-title text-xl text-base-content m-0">Seuils de résultats (Paliers)</h2>
                        <div class="flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary btn-outline rounded-sm" onclick="thresholds_modal.showModal()">
                                + Associer un seuil existant
                            </button>
                            <a href="{{ path('app_admin_stress_threshold_new', {'quiz_id': quiz.id}) }}" class="btn btn-sm btn-primary rounded-sm">
                                + Créer un nouveau seuil
                            </a>
                        </div>
                    </div>
                    
                    <div class="space-y-4">
                    {% for threshold in quiz.stressThresholds %}
                        <div class="card bg-base-200 p-4 rounded-sm border border-base-300 flex flex-row justify-between items-center">
                            <div>
                                <h3 class="font-bold text-base-content">{{ threshold.level }} - {{ threshold.name }}</h3>
                                <p class="text-sm text-base-content/70">Score: {{ threshold.minScore }} à {{ threshold.maxScore }}</p>
                            </div>
                            <div class="flex gap-2 items-center">
                                <a href="{{ path('app_admin_stress_threshold_edit', {id: threshold.id}) }}" class="btn btn-xs btn-outline rounded-sm">Éditer</a>
                                <form action="{{ path('app_admin_quiz_detach_threshold', {id: quiz.id, thresholdId: threshold.id}) }}" method="post" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('detach_threshold' ~ quiz.id) }}">
                                    <button type="submit" class="btn btn-xs btn-warning rounded-sm">Retirer</button>
                                </form>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-sm text-base-content/60">Aucun seuil défini.</p>
                    {% endfor %}
                    </div>
                </div>
            </div>
            
            {# Modal for associating a question #}
            <dialog id="questions_modal" class="modal">
                <div class="modal-box bg-base-100 rounded-sm">
                    <h3 class="font-bold text-lg mb-4 text-base-content">Associer une question</h3>
                    
                    <div class="space-y-2 max-h-96 overflow-y-auto pr-2">
                        {% if available_questions is defined and available_questions|length > 0 %}
                            {% for q in available_questions %}
                                <div class="flex justify-between items-center p-3 bg-base-200 border border-base-300 rounded-sm">
                                    <span class="text-sm font-medium">{{ q.title }}</span>
                                    <form action="{{ path('app_admin_quiz_attach_question', {id: quiz.id, questionId: q.id}) }}" method="post" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('attach_question' ~ quiz.id) }}">
                                        <button type="submit" class="btn btn-xs btn-success text-white rounded-sm">Ajouter</button>
                                    </form>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-sm text-base-content/60">Toutes les questions actives sont déjà associées.</p>
                        {% endif %}
                    </div>
                    
                    <div class="modal-action">
                        <form method="dialog">
                            <button class="btn btn-sm rounded-sm">Fermer</button>
                        </form>
                    </div>
                </div>
                <form method="dialog" class="modal-backdrop">
                    <button>close</button>
                </form>
            </dialog>

            {# Modal for associating a threshold #}
            <dialog id="thresholds_modal" class="modal">
                <div class="modal-box bg-base-100 rounded-sm">
                    <h3 class="font-bold text-lg mb-4 text-base-content">Associer un seuil existant</h3>
                    
                    <div class="space-y-2 max-h-96 overflow-y-auto pr-2">
                        {% if available_thresholds is defined and available_thresholds|length > 0 %}
                            {% for t in available_thresholds %}
                                <div class="flex justify-between items-center p-3 bg-base-200 border border-base-300 rounded-sm">
                                    <span class="text-sm font-medium">{{ t.level }} - {{ t.name }} ({{ t.minScore }}{{ t.maxScore ? ' - ' ~ t.maxScore : ' +' }})</span>
                                    <form action="{{ path('app_admin_quiz_attach_threshold', {id: quiz.id, thresholdId: t.id}) }}" method="post" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('attach_threshold' ~ quiz.id) }}">
                                        <button type="submit" class="btn btn-xs btn-success text-white rounded-sm">Associer</button>
                                    </form>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-sm text-base-content/60">Aucun seuil disponible à associer.</p>
                        {% endif %}
                    </div>
                    
                    <div class="modal-action">
                        <form method="dialog">
                            <button class="btn btn-sm rounded-sm">Fermer</button>
                        </form>
                    </div>
                </div>
                <form method="dialog" class="modal-backdrop">
                    <button>close</button>
                </form>
            </dialog>
            
        {% else %}
            {# Creation mode placeholder #}
            <div class="alert alert-info rounded-sm shadow-sm flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6 mr-2"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span>Veuillez enregistrer ce questionnaire une première fois pour pouvoir y associer des questions et des seuils de résultats.</span>
            </div>
        {% endif %}

        <div class="flex justify-end mt-8">
            <button type="submit" form="quiz_main_form" class="btn btn-primary btn-wide rounded-sm shadow-sm" formnovalidate>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                {{ quiz.id ? 'Enregistrer les modifications' : 'Créer le questionnaire' }}
            </button>
        </div>
{% endblock %}
