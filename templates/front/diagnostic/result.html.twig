{% extends 'base.html.twig' %}

{% block title %}Résultat de votre diagnostic - CESIZen{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Résultat de votre évaluation</h1>
        <p class="text-gray-600">Basé sur l'échelle de "{{ quiz_title }}" réalisé le {{ date|date('d/m/Y') }}.</p>
        
        {% if is_anonymous %}
            <div class="mt-4 inline-flex bg-yellow-50 text-yellow-800 text-sm px-4 py-2 rounded-full border border-yellow-200">
                <svg class="w-5 h-5 mr-1.5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                Vous n'êtes pas connecté. Ce résultat ne sera pas sauvegardé.
            </div>
        {% endif %}
    </div>

    <div class="bg-white shadow-xl rounded-2xl overflow-hidden mb-8 border border-gray-100">
        <div class="p-8 md:p-12 text-center border-b border-gray-100 bg-gray-50">
            <p class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-2">Votre score LCU</p>
            <div class="text-6xl md:text-8xl font-black text-green-700 tracking-tighter">
                {{ score }}
            </div>
            <p class="text-sm text-gray-500 mt-2">Life Change Units (Unités de Changement de Vie)</p>
        </div>

        {% if threshold %}
            <div class="p-8 md:p-12">
                <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 text-center">{{ threshold.name }}</h2>
                
                <div class="prose prose-lg prose-green max-w-none text-gray-700 mb-8">
                    {{ threshold.description|nl2br }}
                </div>

                <div class="bg-indigo-50 rounded-xl p-6 md:p-8 border border-indigo-100">
                    <h3 class="text-xl font-bold text-indigo-900 mb-4 flex items-center">
                        <svg class="w-6 h-6 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                        Recommandations
                    </h3>
                    <div class="text-indigo-800 text-lg">
                        {{ threshold.advice|nl2br }}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="p-12 text-center text-gray-500">
                Impossible de déterminer un profil pour ce score. Veuillez contacter l'administration.
            </div>
        {% endif %}
    </div>

    <div class="flex flex-col sm:flex-row justify-center gap-4">
        {% if is_anonymous %}
            <a href="{{ path('app_register') }}" class="inline-flex justify-center items-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                Créer un compte pour sauvegarder
            </a>
        {% else %}
            <a href="{{ path('app_profile_index') }}" class="inline-flex justify-center items-center px-6 py-3 border border-gray-300 rounded-md shadow-sm text-base font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                Mon historique
            </a>
        {% endif %}
        <a href="{{ path('app_documentation_index') }}" class="inline-flex justify-center items-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-green-700 hover:bg-green-800 transition-colors">
            Voir les ressources
        </a>
    </div>
</div>
{% endblock %}
