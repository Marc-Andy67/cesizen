{% extends 'base.html.twig' %}

{% block title %}Mon Profil - CESIZen{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto bg-white rounded-lg shadow-md overflow-hidden">
    <!-- Header du Profil -->
    <div class="bg-green-800 px-8 py-6 text-white flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold">Mon Profil</h1>
            <p class="text-green-200 mt-2">Gérez vos informations personnelles et vos préférences.</p>
        </div>
        <div class="hidden md:block">
            <svg class="w-16 h-16 text-green-600 opacity-50" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
        </div>
    </div>

    <div class="p-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Historique des Diagnostics -->
            <div class="md:col-span-3 mb-8">
                <h2 class="text-xl font-semibold border-b border-gray-200 pb-2 mb-6 text-gray-800">Historique des évaluations de stress</h2>
                
                {% if assessments is not empty %}
                    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
                        <div class="relative h-64 md:h-80 w-full mb-6">
                            <canvas id="stressHistoryChart"></canvas>
                        </div>
                        
                        <div class="overflow-x-auto mt-6">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead>
                                    <tr>
                                        <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                                        <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Test</th>
                                        <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Score LCU</th>
                                        <th scope="col" class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Détails</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    {% for assessment in assessments %}
                                        <tr>
                                            <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">{{ assessment.date|date('d/m/Y') }}</td>
                                            <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500">{{ assessment.quiz.title }}</td>
                                            <td class="px-4 py-3 whitespace-nowrap text-sm font-bold text-green-700">{{ assessment.totalScore }}</td>
                                            <td class="px-4 py-3 whitespace-nowrap text-sm text-right">
                                                <a href="{{ path('app_diagnostic_result', {'id': assessment.id}) }}" class="text-indigo-600 hover:text-indigo-900 transition-colors">Consulter</a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% else %}
                    <div class="bg-gray-50 px-6 py-10 rounded-lg border border-gray-200 text-center">
                        <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                        <p class="text-gray-500 mb-4">Vous n'avez passé aucun test de diagnostic pour le moment.</p>
                        <a href="{{ path('app_diagnostic_index') }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-700 hover:bg-green-800 transition-colors">
                            Passer un test
                        </a>
                    </div>
                {% endif %}
            </div>

            <!-- Formulaire de modification -->
            <div class="md:col-span-2">
                <h2 class="text-xl font-semibold border-b border-gray-200 pb-2 mb-6 text-gray-800">Mes informations</h2>
                
                {{ form_start(profileForm, {'attr': {'class': 'space-y-6'}}) }}
                    
                    <div>
                        {{ form_label(profileForm.name, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                        {{ form_widget(profileForm.name) }}
                        <div class="text-sm text-red-600 mt-1">
                            {{ form_errors(profileForm.name) }}
                        </div>
                    </div>

                    <div>
                        {{ form_label(profileForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                        {{ form_widget(profileForm.email) }}
                        <div class="text-sm text-red-600 mt-1">
                            {{ form_errors(profileForm.email) }}
                        </div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-700 hover:bg-green-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
                            Enregistrer les modifications
                        </button>
                    </div>

                {{ form_end(profileForm) }}
            </div>

            <!-- Paramètres RGPD & Sécurité -->
            <div>
                <h2 class="text-xl font-semibold border-b border-gray-200 pb-2 mb-6 text-gray-800">Paramètres de sécurité</h2>
                
                <div class="space-y-6">
                    <!-- Exportation JSON -->
                    <div class="bg-blue-50 p-4 rounded-md border border-blue-100">
                        <h3 class="text-md font-medium text-blue-800 mb-2 flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            Exporter mes données
                        </h3>
                        <p class="text-sm text-blue-700 mb-4">Téléchargez toutes vos données personnelles au format JSON (RGPD).</p>
                        <a href="{{ path('app_profile_export_data') }}" class="inline-flex w-full justify-center py-2 px-4 shadow-sm text-sm font-medium rounded-md text-blue-700 bg-white border border-blue-300 hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                            Télécharger l'archive
                        </a>
                    </div>
                    
                    <!-- Réinitialisation de mot de passe -->
                    <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                        <h3 class="text-md font-medium text-gray-800 mb-2">Mot de passe</h3>
                        <p class="text-sm text-gray-600 mb-4">Mettre à jour vos identifiants.</p>
                        <a href="{{ path('app_forgot_password_request') }}" class="inline-flex w-full justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
                            Changer mon mot de passe
                        </a>
                    </div>

                    <!-- Suppression de compte -->
                    <div class="bg-red-50 p-4 rounded-md border border-red-100 mt-8">
                        <h3 class="text-md font-medium text-red-800 mb-2 flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            Zone de danger
                        </h3>
                        <p class="text-sm text-red-700 mb-4">Cette action anonymisera définitivement vos données. Elle est irréversible.</p>
                        
                        <form method="post" action="{{ path('app_profile_delete') }}" onsubmit="return confirm('Êtes-vous absolument certain(e) de vouloir supprimer définitivement votre compte ? Cette action est irréversible et vos données associées seront anonymisées.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                            <button type="submit" class="w-full flex justify-center py-2 px-4 shadow-sm text-sm font-medium rounded-md text-white border border-red-600 bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors">
                                Supprimer mon compte
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    {% if assessments is not empty %}
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const ctx = document.getElementById('stressHistoryChart').getContext('2d');
                
                const labels = {{ chartDates|raw }};
                const dataPoints = {{ chartScores|raw }};
                
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Score LCU (Niveau de Stress)',
                            data: dataPoints,
                            borderColor: '#15803d', // Tailwind green-700
                            backgroundColor: 'rgba(21, 128, 61, 0.1)',
                            borderWidth: 3,
                            pointBackgroundColor: '#15803d',
                            pointBorderColor: '#ffffff',
                            pointHoverBackgroundColor: '#ffffff',
                            pointHoverBorderColor: '#15803d',
                            pointRadius: 5,
                            pointHoverRadius: 7,
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top',
                            },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                backgroundColor: 'rgba(255, 255, 255, 0.9)',
                                titleColor: '#1f2937',
                                bodyColor: '#1f2937',
                                borderColor: '#e5e7eb',
                                borderWidth: 1
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Score LCU'
                                },
                                // On peut ajouter des lignes de référence pour les seuils si on les connaît
                                // Dans un monde idéal on les passe via le contrôleur, ou on laisse Chart.js gérer
                            },
                            x: {
                                title: {
                                    display: true,
                                    text: 'Date d\'évaluation'
                                }
                            }
                        },
                        interaction: {
                            mode: 'nearest',
                            axis: 'x',
                            intersect: false
                        }
                    }
                });
            });
        </script>
    {% endif %}
{% endblock %}
{% endblock %}
