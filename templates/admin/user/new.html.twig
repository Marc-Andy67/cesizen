{% extends 'admin/base.html.twig' %}

{% block title %}Créer un administrateur{% endblock %}

{% block body %}
    <div class="mb-6 flex justify-between items-center">
        <h1 class="text-2xl font-bold">Créer un administrateur</h1>
        <a href="{{ path('app_admin_user_index') }}" class="btn btn-outline">Annuler</a>
    </div>

    <div class="card bg-base-100 shadow-xl max-w-2xl mx-auto">
        <div class="card-body">
            {{ form_start(form) }}
            
            <div class="form-control w-full mb-4">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-control w-full mb-4">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-control w-full mb-6">
                {{ form_label(form.password) }}
                {{ form_widget(form.password) }}
                
                <div id="password-checklist" aria-live="polite" class="bg-base-200 rounded p-3 mt-2 text-sm">
                    <ul class="space-y-1">
                        <li id="req-length" class="text-error transition-colors duration-200"><span class="icon mr-1">✗</span> Au moins 12 caractères</li>
                        <li id="req-upper" class="text-error transition-colors duration-200"><span class="icon mr-1">✗</span> Une lettre majuscule (A-Z)</li>
                        <li id="req-lower" class="text-error transition-colors duration-200"><span class="icon mr-1">✗</span> Une lettre minuscule (a-z)</li>
                        <li id="req-number" class="text-error transition-colors duration-200"><span class="icon mr-1">✗</span> Un chiffre (0-9)</li>
                        <li id="req-special" class="text-error transition-colors duration-200"><span class="icon mr-1">✗</span> Un caractère spécial (!@#$%^&*...)</li>
                    </ul>
                </div>
                
                {{ form_errors(form.password) }}
            </div>

            <div class="card-actions justify-end">
                <button type="submit" class="btn" style="background-color: #2D6A4F; color: white;">Créer l'administrateur</button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const passwordInput = document.querySelector('input[type="password"]');
            if (!passwordInput) return;

            const criteria = {
                'req-length': (v) => v.length >= 12,
                'req-upper': (v) => /[A-Z]/.test(v),
                'req-lower': (v) => /[a-z]/.test(v),
                'req-number': (v) => /[0-9]/.test(v),
                'req-special': (v) => /[!@#$%^&*()_+\-=\[\]{}|;:,.<>?]/.test(v)
            };

            passwordInput.addEventListener('input', (e) => {
                const value = e.target.value;
                for (const [id, testFn] of Object.entries(criteria)) {
                    const el = document.getElementById(id);
                    if (!el) continue;
                    
                    const icon = el.querySelector('.icon');
                    if (testFn(value)) {
                        el.classList.remove('text-error');
                        el.classList.add('text-success');
                        icon.textContent = '✓';
                    } else {
                        el.classList.remove('text-success');
                        el.classList.add('text-error');
                        icon.textContent = '✗';
                    }
                }
            });
        });
    </script>
{% endblock %}
