{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="mb-6 border-b pb-4 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">Modifier : {{ question.title|slice(0, 30) }}...</h1>
        <a href="{{ path('app_admin_question_index') }}" class="text-gray-500 hover:text-gray-700 transition-colors">
            &larr; Retour à la liste
        </a>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 max-w-3xl">
        {{ include('admin/question/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function initQuestionForm() {
            const wrapper = document.getElementById('responses-wrapper');
            const addButton = document.getElementById('add-response');
            if (!wrapper || !addButton) return;
            
            // Remove previous event listeners to avoid duplicates if Turbo loads multiple times
            const newAddButton = addButton.cloneNode(true);
            addButton.parentNode.replaceChild(newAddButton, addButton);
            
            let index = parseInt(wrapper.dataset.index) || 0;
            
            newAddButton.addEventListener('click', function() {
                let visualIndex = document.querySelectorAll('.response-item').length + 1;
                const prototype = wrapper.dataset.prototype;
                const newFormStr = prototype.replace(/__name__/g, index).replace(/__number__/g, visualIndex);
                
                const temp = document.createElement('div');
                temp.innerHTML = newFormStr.trim();
                wrapper.appendChild(temp.firstChild);
                
                index++;
            });
            
            // For event delegation, ensure we don't bind multiple times on wrapper
            wrapper.onclick = function(e) {
                const removeBtn = e.target.closest('.btn-remove-response');
                if (removeBtn) {
                    if (confirm('Êtes-vous sûr de vouloir supprimer cette réponse ? (La suppression sera définitive après l\'enregistrement du formulaire)')) {
                        removeBtn.closest('.response-item').remove();
                        document.querySelectorAll('.response-number').forEach((badge, idx) => {
                            badge.textContent = 'Réponse ' + (idx + 1);
                        });
                    }
                }
            };
        }

        document.addEventListener('DOMContentLoaded', initQuestionForm);
        document.addEventListener('turbo:load', initQuestionForm);
        document.addEventListener('turbo:render', initQuestionForm);
    </script>
{% endblock %}
