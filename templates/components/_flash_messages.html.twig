{#
    Composant qui lit automatiquement les messages flash de la session Symfony
    et les affiche en utilisant _alert.html.twig.
#}

{% for label, messages in app.flashes %}
    {# Mappons les labels Symfony standards vers les types de notre composant Alert #}
    {% set alert_type = label %}
    {% if label == 'danger' %}
        {% set alert_type = 'error' %}
    {% endif %}

    <div class="mb-4 animate-fade-in">
        {% for message in messages %}
            {{ include('components/_alert.html.twig', {
                message: message,
                type: alert_type,
                dismissible: true
            }) }}
        {% endfor %}
    </div>
{% endfor %}
