<!DOCTYPE html>
<html lang="fr" data-theme="cesizen" class="bg-base-100">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Diagnostic de stress — CESIZen{% endblock %}</title>
        <link rel="icon" href="/favicon.ico">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="text-base-content font-sans antialiased">
        {# RGAA : Skip link pour aller directement au contenu principal #}
        {{ include('components/_skip_link.html.twig') }}

        <div class="drawer">
            <input id="mobile-menu" type="checkbox" class="drawer-toggle" />
            <div class="drawer-content flex flex-col min-h-screen">
                
                <!-- Bandeau République Française DSFR -->
                <div class="bg-primary text-white text-[0.65rem] sm:text-xs py-2 border-b border-primary-content/20">
                  <div class="container mx-auto px-4 flex flex-wrap items-center gap-2 sm:gap-3">
                    <div class="flex items-center gap-1.5 font-bold leading-none tracking-tight">
                        <span class="text-blue-200">Liberté</span>
                        <span class="text-white">Égalité</span>
                        <span class="text-red-300">Fraternité</span>
                    </div>
                    <span class="opacity-50 hidden sm:inline">|</span>
                    <span class="font-medium tracking-wide uppercase">République Française</span>
                  </div>
                </div>

                <!-- Header Principal CESIZen -->
                <header class="bg-white shadow-sm border-b border-base-300 relative z-30">
                    <div class="container mx-auto px-4 py-2 navbar">
                        <!-- Mobile Toggle -->
                        <div class="flex-none lg:hidden">
                            <label for="mobile-menu" aria-label="Ouvrir le menu" class="btn btn-square btn-ghost text-primary">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                            </label>
                        </div>

                        <!-- Brand / Logo -->
                        <div class="flex-1 px-2 mx-2">
                            <a href="{{ path('app_home') }}" class="flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-info rounded-sm outline-none transition-all duration-200" aria-label="Retour à l'accueil CESIZen">
                                <svg class="w-8 h-8 text-accent" viewBox="0 0 24 24" fill="currentColor">
                                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                                </svg>
                                <span class="text-2xl font-bold tracking-tight text-primary">CESI<span class="text-accent">Zen</span></span>
                            </a>
                        </div>

                        <!-- Desktop Menu -->
                        <div class="flex-none hidden lg:block">
                            <ul class="menu menu-horizontal px-1 gap-1">
                                <li>
                                    <a href="{{ path('app_documentation_index') }}" class="font-medium text-neutral hover:bg-base-200 focus-visible:ring-2 focus-visible:ring-info outline-none rounded-md transition-all duration-200">
                                        Ressources
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_diagnostic_index') }}" class="font-medium text-neutral hover:bg-base-200 focus-visible:ring-2 focus-visible:ring-info outline-none rounded-md transition-all duration-200">
                                        Diagnostic Holmes & Rahe
                                    </a>
                                </li>
                            </ul>
                        </div>

                        <!-- User Profile / Auth -->
                        <div class="flex-none ml-2 sm:ml-4">
                            {% if app.user %}
                                <div class="dropdown dropdown-end">
                                    <label tabindex="0" class="btn btn-ghost btn-circle avatar border border-base-300 focus-visible:ring-2 focus-visible:ring-info outline-none transition-all duration-200" aria-label="Menu utilisateur">
                                        <div class="w-10 rounded-full bg-base-200 flex items-center justify-center text-primary font-bold">
                                            {{ app.user.name|default(app.user.email)|slice(0, 1)|upper }}
                                        </div>
                                    </label>
                                    <ul tabindex="0" class="mt-3 z-[1] p-2 shadow-lg menu menu-sm dropdown-content bg-white rounded-box w-64 border border-base-200">
                                        <li class="menu-title px-4 py-2 text-xs font-semibold text-primary uppercase border-b border-base-200 mb-2 truncate">
                                            {{ app.user.name|default(app.user.email) }}
                                        </li>
                                        <li>
                                            <a href="{{ path('app_profile_index') }}" class="focus-visible:ring-2 focus-visible:ring-info outline-none rounded transition-all duration-200">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-70" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" /></svg>
                                                Mon Espace
                                            </a>
                                        </li>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <li>
                                                <a href="{{ path('admin_dashboard') }}" class="text-warning font-medium focus-visible:ring-2 focus-visible:ring-info outline-none rounded transition-all duration-200">
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-70" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" /></svg>
                                                    Administration
                                                    <span class="badge badge-warning badge-sm ml-auto">Admin</span>
                                                </a>
                                            </li>
                                        {% endif %}
                                        <li class="border-t border-base-200 mt-2 pt-2">
                                            <a href="{{ path('app_logout') }}" class="text-error font-medium focus-visible:ring-2 focus-visible:ring-info outline-none rounded transition-all duration-200">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-70" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd" /></svg>
                                                Déconnexion
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            {% else %}
                                <div class="flex gap-2">
                                    <a href="{{ path('app_login') }}" class="btn btn-ghost btn-sm text-primary focus-visible:ring-2 focus-visible:ring-info outline-none transition-all duration-200 hidden sm:flex">Connexion</a>
                                    <a href="{{ path('app_register') }}" class="btn btn-primary btn-sm focus-visible:ring-2 focus-visible:ring-info outline-none transition-all duration-200">Créer un compte</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </header>

                <!-- Zone de Contenu Principale -->
                <main id="main-content" class="flex-grow focus:outline-none" tabindex="-1">
                    {# Messages flash (succès, erreurs) #}
                    <div class="container mx-auto px-4 mt-6">
                        {{ include('components/_flash_messages.html.twig') }}
                    </div>
                    
                    {% block body %}{% endblock %}
                </main>

                <!-- Footer DSFR -->
                <footer class="bg-white border-t-2 border-primary pt-12 mt-auto text-neutral">
                    <div class="container mx-auto px-4 pb-8">
                        <div class="flex flex-col md:flex-row gap-8 lg:gap-12 items-start justify-between">
                            
                            <div class="md:w-1/3 flex flex-col gap-4">
                                <div class="flex items-center gap-4 pb-4 border-base-300">
                                    <div class="flex flex-col font-bold text-[1.1rem] leading-[1.1] text-neutral uppercase tracking-tighter">
                                        <span>MINISTÈRE</span>
                                        <span>DE LA SANTÉ</span>
                                        <span>ET DE LA PRÉVENTION</span>
                                    </div>
                                    <div class="w-16 h-auto border-l-2 border-primary pl-4">
                                        <svg viewBox="0 0 100 100" fill="currentColor" class="text-primary opacity-80" aria-hidden="true"><path d="M50 0a50 50 0 100 100A50 50 0 0050 0zm0 90a40 40 0 110-80 40 40 0 010 80z"/></svg>
                                    </div>
                                </div>
                                <p class="text-sm font-medium mt-2 leading-relaxed max-w-sm">
                                    Ce site est géré par le Ministère de la Santé et de la Prévention.<br>
                                    <span class="opacity-80 font-normal">CESIZen a pour mission d'accompagner les citoyens dans l'évaluation et la prise en charge de leur santé mentale et de leur stress au quotidien.</span>
                                </p>
                            </div>

                            <div class="md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-8 w-full md:pl-12 lg:pl-20 border-t md:border-t-0 md:border-l border-base-200 pt-8 md:pt-0">
                                <div>
                                    <h2 class="font-bold text-primary text-lg mb-4">À propos</h2>
                                    <ul class="space-y-3 text-sm flex flex-col items-start font-medium">
                                        <li><a href="{{ path('app_home') }}" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">Accueil CESIZen</a></li>
                                        <li><a href="{{ path('app_diagnostic_index') }}" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">Faire le test Holmes & Rahe</a></li>
                                        <li><a href="{{ path('app_documentation_index') }}" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">Ressources & Documentation</a></li>
                                    </ul>
                                </div>
                                <div>
                                    <h2 class="font-bold text-primary text-lg mb-4">Obligations légales</h2>
                                    <ul class="space-y-3 text-sm flex flex-col items-start font-medium">
                                        <li><a href="#" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">Plan du site</a></li>
                                        <li><a href="#" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">Accessibilité : non conforme</a></li>
                                        <li><a href="#" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">Mentions légales</a></li>
                                        <li><a href="#" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">CGU</a></li>
                                        <li><a href="#" class="hover:text-primary focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm transition-all duration-200 inline-block px-1 -ml-1">Politique de confidentialité</a></li>
                                    </ul>
                                </div>
                            </div>

                        </div>
                    </div>
                    <div class="bg-base-200 py-4 text-xs text-center border-t border-base-300 shadow-inner">
                        <div class="container mx-auto px-4 opacity-70">
                            Sauf mention contraire, tous les contenus de ce site sont sous licence <a href="https://github.com/etalab/licence-ouverte" target="_blank" rel="noopener noreferrer" class="font-bold hover:underline focus-visible:ring-2 focus-visible:ring-info outline-none rounded-sm">etalab-2.0</a>
                        </div>
                    </div>
                </footer>

            </div> 
            
            <!-- Sidebar mobile (Drawer DaisyUI) -->
            <div class="drawer-side z-40">
                <label for="mobile-menu" aria-label="Fermer le menu" class="drawer-overlay"></label>
                <ul class="menu p-4 w-80 min-h-full bg-base-100 text-base-content pt-6 gap-2 shadow-2xl">
                    <li class="mb-4 flex flex-row items-center gap-2 cursor-pointer pb-2 border-b border-base-200">
                        <svg class="w-6 h-6 text-accent" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                        </svg>
                        <span class="text-xl font-bold text-primary tracking-tight">CESI<span class="text-accent">Zen</span></span>
                    </li>
                    <li class="menu-title text-primary uppercase font-bold text-[0.65rem] tracking-wider">Navigation</li>
                    <li><a href="{{ path('app_home') }}" class="focus-visible:ring-2 focus-visible:ring-info outline-none font-medium text-[0.95rem]">Accueil</a></li>
                    <li><a href="{{ path('app_diagnostic_index') }}" class="focus-visible:ring-2 focus-visible:ring-info outline-none font-medium text-[0.95rem]">Faire mon diagnostic</a></li>
                    <li><a href="{{ path('app_documentation_index') }}" class="focus-visible:ring-2 focus-visible:ring-info outline-none font-medium text-[0.95rem]">Ressources documentaires</a></li>
                    
                    {% if not app.user %}
                        <li class="menu-title mt-6 text-primary uppercase font-bold text-[0.65rem] tracking-wider border-t border-base-200 pt-4">Votre Espace</li>
                        <li><a href="{{ path('app_login') }}" class="focus-visible:ring-2 focus-visible:ring-info outline-none bg-base-200 mt-2 font-medium">Se connecter</a></li>
                        <li><a href="{{ path('app_register') }}" class="focus-visible:ring-2 focus-visible:ring-info outline-none bg-primary text-white mt-2 hover:bg-secondary font-medium">Créer un compte libre</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>

    </body>
</html>