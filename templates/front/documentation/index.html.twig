{% extends 'base.html.twig' %}

{% block title %}Vidéos & Documentations - CESIZen{% endblock %}

{% block body %}
    <div class="mb-10 text-center">
        <h1 class="text-4xl font-extrabold text-gray-800 mb-4">Ressources & Prévention</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">Explorez notre base de connaissances sur la santé mentale, le stress et les méthodes de relaxation.</p>
    </div>

    <div class="flex flex-col md:flex-row gap-8">
        {# Filtres par catégorie #}
        <aside class="w-full md:w-64 flex-shrink-0">
            <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-5 sticky top-8">
                <h2 class="font-bold text-lg text-gray-800 mb-4 border-b pb-2">Catégories</h2>
                <ul class="space-y-2">
                    <li>
                        <a href="{{ path('app_documentation_index') }}" class="block px-3 py-2 rounded-md transition-colors {{ not current_category ? 'bg-green-100 text-green-800 font-medium' : 'text-gray-600 hover:bg-gray-50' }}">
                            Toutes les ressources
                        </a>
                    </li>
                    {% for category in categories %}
                        <li>
                            <a href="{{ path('app_documentation_index', {'category': category.id}) }}" class="block px-3 py-2 rounded-md transition-colors {{ current_category == category.id ? 'bg-green-100 text-green-800 font-medium' : 'text-gray-600 hover:bg-gray-50' }}">
                                {{ category.name }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </aside>

        {# Liste des documentations #}
        <div class="flex-grow">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for doc in pagination %}
                    <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow flex flex-col h-full transform hover:-translate-y-1 duration-200">
                        <div class="p-6 flex-grow flex flex-col">
                            <div class="mb-3 flex flex-wrap gap-1">
                                {% for cat in doc.categories|slice(0, 2) %}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                                        {{ cat.name }}
                                    </span>
                                {% endfor %}
                            </div>
                            
                            <h3 class="text-xl font-bold text-gray-900 mb-2 leading-tight">
                                <a href="{{ path('app_documentation_show', {'id': doc.id}) }}" class="hover:text-green-700 transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 rounded px-1">
                                    {{ doc.title }}
                                </a>
                            </h3>
                            
                            {# Afficher un extrait du contenu (retirer le HTML) #}
                            <p class="text-gray-600 text-sm mb-4 flex-grow line-clamp-3">
                                {{ doc.content|striptags|slice(0, 150) ~ '...' }}
                            </p>
                            
                            <div class="mt-auto pt-4 border-t border-gray-100">
                                <a href="{{ path('app_documentation_show', {'id': doc.id}) }}" class="text-green-700 font-medium hover:text-green-800 transition-colors inline-flex items-center focus:outline-none focus:ring-2 focus:ring-green-500 rounded px-1 group">
                                    Lire l'article
                                    <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </a>
                            </div>
                        </div>
                    </article>
                {% else %}
                    <div class="col-span-full bg-gray-50 border border-gray-200 rounded-lg p-10 text-center text-gray-500">
                        <svg class="w-12 h-12 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Aucune documentation n'est disponible dans cette catégorie pour le moment.
                    </div>
                {% endfor %}
            </div>

            {# Pagination #}
            <div class="mt-8">
                {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
