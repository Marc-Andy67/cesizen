{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h1 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue tracking-tight">Gestion des Questionnaires</h1>
        
        {{ include('components/_button.html.twig', {
            label: 'Nouveau Questionnaire',
            variant: 'primary',
            attr: 'href="' ~ path('app_admin_quiz_new') ~ '"',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>'
        }) }}
    </div>

    <div class="overflow-x-auto rounded-sm border border-base-200">
        <table class="table table-zebra table-sm md:table-md w-full">
            <thead class="bg-base-200 text-base-content">
                <tr>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Titre</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Nb Questions</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Statut</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for quiz in quizzes %}
                    <tr class="hover">
                        <td>
                            <span class="font-bold text-base-content">{{ quiz.title }}</span>
                        </td>
                        <td>
                            <span class="text-sm font-medium text-base-content/80">{{ quiz.questions|length }}</span>
                        </td>
                        <td>
                            {% if quiz.isActive %}
                                {{ include('components/_badge.html.twig', { label: 'Actif', variant: 'success', rounded: true }) }}
                            {% else %}
                                {{ include('components/_badge.html.twig', { label: 'Inactif', variant: 'neutral', rounded: true }) }}
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <div class="flex justify-end gap-2 items-center">
                                <a href="{{ path('app_admin_quiz_edit', {'id': quiz.id}) }}" class="btn btn-xs rounded-sm btn-ghost border border-base-300 text-dsfr-blue font-medium">Éditer</a>
                                
                                <form method="post" action="{{ path('app_admin_quiz_toggle', {'id': quiz.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir {% if quiz.isActive %}désactiver{% else %}activer{% endif %} ce questionnaire ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ quiz.id) }}">
                                    <button class="btn btn-xs rounded-sm btn-ghost border {% if quiz.isActive %}border-error text-error{% else %}border-success text-success{% endif %} font-medium">
                                        {% if quiz.isActive %}Désactiver{% else %}Activer{% endif %}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="py-12 text-center text-base-content/60 font-medium">
                            Aucun questionnaire trouvé.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>


{% endblock %}
