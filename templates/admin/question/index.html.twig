{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h1 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue tracking-tight">Gestion des Questions</h1>
        
        {{ include('components/_button.html.twig', {
            label: 'Nouvelle Question',
            variant: 'primary',
            attr: 'href="' ~ path('app_admin_question_new') ~ '"',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>'
        }) }}
    </div>

    <div class="overflow-x-auto rounded-sm border border-base-200">
        <table class="table table-zebra table-sm md:table-md w-full">
            <thead class="bg-base-200 text-base-content">
                <tr>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Titre / Événement</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Statut</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for question in pagination %}
                    <tr class="hover">
                        <td>
                            <span class="font-bold text-base-content">{{ question.title }}</span>
                        </td>
                        <td>
                            {% if question.isActive %}
                                {{ include('components/_badge.html.twig', { label: 'Actif', variant: 'success', rounded: true }) }}
                            {% else %}
                                {{ include('components/_badge.html.twig', { label: 'Inactif', variant: 'neutral', rounded: true }) }}
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <div class="flex justify-end gap-2">
                                <a href="{{ path('app_admin_question_edit', {'id': question.id}) }}" class="btn btn-xs rounded-sm btn-ghost border border-base-300 text-dsfr-blue font-medium">Éditer</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="py-12 text-center text-base-content/60 font-medium">
                            Aucune question trouvée.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.getTotalItemCount > 0 %}
        <div class="mt-6 flex justify-center">
            {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
        </div>
    {% endif %}
{% endblock %}
