{% extends 'base.html.twig' %}

{% block title %}Accueil - CESIZen{% endblock %}

{% block body %}
    <div class="flex flex-col gap-16 py-8 md:py-16">
        
        {# HERO SECTION #}
        <section class="flex flex-col md:flex-row items-center justify-between gap-12" aria-labelledby="hero-title">
            <div class="md:w-1/2 flex flex-col items-center text-center gap-6 animate-fade-in">
                <div class="inline-flex">
                    <span class="bg-base-200 text-dsfr-blue font-bold text-xs uppercase tracking-wider px-3 py-1 border border-base-300">Santé Mentale & Bien-être</span>
                </div>
                <h1 id="hero-title" class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dsfr-blue tracking-tight leading-tight">
                    Prenez soin de votre <br>
                    <span class="text-dsfr-blue-light">Santé Mentale</span>
                </h1>
                
                <p class="text-lg md:text-xl text-base-content/80 max-w-2xl leading-relaxed">
                    1 Français sur 5 est touché par des troubles mentaux chaque année. Évaluez votre niveau de stress selon l'échelle de Holmes & Rahe, découvrez des ressources adaptées et prenez les mesures nécessaires pour améliorer votre bien-être au quotidien.
                </p>

                <div class="flex flex-col sm:flex-row justify-center gap-4 mt-4">
                    {{ include('components/_button.html.twig', {
                        label: 'Faire mon diagnostic',
                        variant: 'primary',
                        size: 'lg',
                        attr: 'href="' ~ path('app_diagnostic_index') ~ '"'
                    }) }}
                    
                    {{ include('components/_button.html.twig', {
                        label: 'En savoir plus',
                        variant: 'outline',
                        size: 'lg',
                        attr: 'href="' ~ path('app_documentation_index') ~ '"'
                    }) }}
                </div>
            </div>
            
            <div class="md:w-1/2 flex justify-center lg:justify-end">
                <div class="relative w-full max-w-md aspect-square bg-base-100 rounded-full flex items-center justify-center border-8 border-white shadow-xl overflow-hidden before:absolute before:inset-0 before:bg-gradient-to-tr before:from-dsfr-blue/5 before:to-dsfr-green/5">
                    <img src="{{ asset('images/logo.webp') }}" alt="Logo CESIZen : Tête de profil avec un cerveau en forme de lotus" class="w-2/3 h-2/3 object-contain z-10 relative drop-shadow-sm hover:scale-105 transition-transform duration-500" />
                </div>
            </div>
        </section>

        {# MODULES CARDS #}
        <section aria-labelledby="modules-title" class="my-8">
            <h2 id="modules-title" class="sr-only">Nos services</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {{ include('components/_card.html.twig', {
                    title: 'Diagnostic de stress',
                    badge: 'Recommandé',
                    badge_variant: 'new',
                    content: "Testez votre vulnérabilité au stress grâce à l'échelle d'événements de vie développée par les psychiatres Holmes et Rahe. Ce questionnaire validé scientifiquement estime votre risque de développer un terrain d'épuisement mental à court terme.",
                    clickable_url: path('app_diagnostic_index'),
                    footer: include('components/_button.html.twig', { label: 'Démarrer le test', variant: 'outline', size: 'sm', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />', attr: 'href="' ~ path('app_diagnostic_index') ~ '"' })
                }) }}

                {{ include('components/_card.html.twig', {
                    title: 'Ressources éducatives',
                    badge: 'Expertise',
                    badge_variant: 'success',
                    content: "Consultez notre base documentaire rédigée et validée par des professionnels de santé. Découvrez comment comprendre les mécanismes du stress, identifier les premiers signaux d'alerte et mettre en place des routines saines au quotidien.",
                    clickable_url: path('app_documentation_index'),
                    footer: include('components/_button.html.twig', { label: 'Explorer', variant: 'outline', size: 'sm', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />', attr: 'href="' ~ path('app_documentation_index') ~ '"' })
                }) }}

                {{ include('components/_card.html.twig', {
                    title: 'Mon Espace',
                    badge: 'Sécurisé',
                    badge_variant: 'neutral',
                    content: "Retrouvez l'historique complet de vos diagnostics avec des courbes de progression personnalisées. Vos données sont anonymisées, hébergées en France sur des serveurs HDS (Hébergeur de Données de Santé) et totalement privées.",
                    clickable_url: path('app_profile_index'),
                    footer: include('components/_button.html.twig', { label: 'Gérer mon profil', variant: 'outline', size: 'sm', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />', attr: 'href="' ~ path('app_profile_index') ~ '"' })
                }) }}
            </div>
        </section>

        {# STATISTIQUES #}
        <section aria-labelledby="stats-title" class="bg-base-200 -mx-4 px-4 py-16 sm:-mx-8 sm:px-8 lg:-mx-16 lg:px-16 lg:rounded-sm">
            <div class="text-center mb-10">
                <h2 id="stats-title" class="text-3xl font-bold text-dsfr-blue mb-4">Le diagnostic en chiffres</h2>
                <p class="text-base-content/70">Un outil validé et accessible à tous pour évaluer sa vulnérabilité au stress dans ses différentes composantes : vie personnelle, professionnelle et familiale.</p>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {{ include('components/_stat.html.twig', {
                    value: '43',
                    label: "Événements de vie évalués (Holmes & Rahe)",
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />'
                }) }}
                
                {{ include('components/_stat.html.twig', {
                    value: '4',
                    label: "Niveaux de mesure de l'épuisement mental calculés",
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />'
                }) }}
                
                {{ include('components/_stat.html.twig', {
                    value: '100%',
                    label: 'Conforme RGPD, hébergé en France et gratuit',
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />'
                }) }}
                
                {{ include('components/_stat.html.twig', {
                    value: '0',
                    label: "Traces commerciales (données non exploitées)",
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z" />'
                }) }}
            </div>
        </section>

        {# URGENCE #}
        <section aria-labelledby="urgence-title" class="bg-red-50 border-l-4 border-dsfr-red p-6 sm:p-10 mb-8 rounded-r-lg shadow-sm">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-dsfr-red" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <h2 id="urgence-title" class="text-2xl font-bold text-dsfr-red m-0">Vous êtes en situation de détresse ?</h2>
                    </div>
                    <p class="text-dsfr-red font-medium text-lg mt-2">
                        Le <a href="tel:3114" class="font-bold underline hover:text-red-900 focus-visible:ring-2 focus-visible:ring-dsfr-red outline-none rounded-sm transition-colors">3114</a> est le numéro national de prévention du suicide. 
                        Professionnels appelables 24h/24 et 7j/7, appel confidentiel et gratuit.
                    </p>
                </div>
                
                {{ include('components/_button.html.twig', {
                    label: 'Appeler le 3114',
                    variant: 'danger',
                    size: 'lg',
                    attr: 'href="' ~ path('app_home') ~ '"',
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />'
                }) }}
            </div>
        </section>

    </div>
{% endblock %}
