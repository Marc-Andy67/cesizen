{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h1 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue tracking-tight">Gestion des Réponses</h1>
        
        {{ include('components/_button.html.twig', {
            label: 'Nouvelle Réponse',
            variant: 'primary',
            attr: 'href="' ~ path('app_admin_response_new') ~ '"',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>'
        }) }}
    </div>

    <div class="overflow-x-auto rounded-sm border border-base-200">
        <table class="table table-zebra table-sm md:table-md w-full">
            <thead class="bg-base-200 text-base-content">
                <tr>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Question liée</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Réponse</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Points LCU</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Statut</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for response in pagination %}
                    <tr class="hover">
                        <td>
                            <span class="text-sm text-base-content/80 block w-48 truncate">{{ response.question.title }}</span>
                        </td>
                        <td>
                            <span class="font-bold text-base-content">{{ response.description }}</span>
                        </td>
                        <td>
                            <span class="font-extrabold text-dsfr-blue">{{ response.points }}</span>
                        </td>
                        <td>
                            {% if response.isActive %}
                                {{ include('components/_badge.html.twig', { label: 'Actif', variant: 'success', rounded: true }) }}
                            {% else %}
                                {{ include('components/_badge.html.twig', { label: 'Inactif', variant: 'neutral', rounded: true }) }}
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <div class="flex justify-end gap-2">
                                <a href="{{ path('app_admin_response_edit', {'id': response.id}) }}" class="btn btn-xs rounded-sm btn-ghost border border-base-300 text-dsfr-blue font-medium">Éditer</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="py-12 text-center text-base-content/60 font-medium">
                            Aucune réponse trouvée.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.getTotalItemCount > 0 %}
        <div class="mt-6 flex justify-center">
            {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
        </div>
    {% endif %}
{% endblock %}
