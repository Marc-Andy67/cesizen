{% extends 'base.html.twig' %}

{% block title %}Administration - CESIZen{% endblock %}

{% block body %}
    <div class="py-8 md:py-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row gap-8 animate-fade-in">
        
        {# Sidebar Admin #}
        <aside class="w-full lg:w-72 flex-shrink-0">
            <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm sticky top-8">
                <div class="card-body p-4 sm:p-6">
                    <h2 class="font-bold text-lg text-dsfr-blue mb-4 border-b-2 border-base-200 pb-2 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        Admin CESIZen
                    </h2>
                    
                    <ul class="menu p-0 w-full gap-1">
                        <li>
                            <a href="{{ path('app_admin_dashboard') }}" class="rounded-sm font-medium {% if app.request.attributes.get('_route') == 'app_admin_dashboard' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Tableau de bord
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_admin_user_index') }}" class="rounded-sm font-medium {% if app.request.attributes.get('_route') starts with 'app_admin_user_' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Utilisateurs
                            </a>
                        </li>
                        
                        <li class="menu-title mt-4 mb-2 pb-1 border-b border-base-200 uppercase text-[0.65rem] tracking-wider font-bold {% if (app.request.attributes.get('_route') starts with 'app_admin_category_') or (app.request.attributes.get('_route') starts with 'app_admin_documentation_') %}bg-base-200 text-dsfr-blue rounded-sm px-3{% else %}text-base-content/60{% endif %}">Contenu</li>
                        <li>
                            <a href="{{ path('app_admin_category_index') }}" class="rounded-sm font-medium {% if app.request.attributes.get('_route') starts with 'app_admin_category_' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Catégories
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_admin_documentation_index') }}" class="rounded-sm font-medium {% if app.request.attributes.get('_route') starts with 'app_admin_documentation_' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Documentations
                            </a>
                        </li>
                        
                        <li class="menu-title mt-4 mb-2 pb-1 border-b border-base-200 uppercase text-[0.65rem] tracking-wider font-bold {% if (app.request.attributes.get('_route') starts with 'app_admin_quiz_') or (app.request.attributes.get('_route') starts with 'app_admin_question_') or (app.request.attributes.get('_route') starts with 'app_admin_response_') or (app.request.attributes.get('_route') starts with 'app_admin_stress_threshold_') %}bg-base-200 text-dsfr-blue rounded-sm px-3{% else %}text-base-content/60{% endif %}">Diagnostics</li>
                        <li>
                            <a href="{{ path('app_admin_quiz_index') }}" class="rounded-sm font-medium {% if app.request.attributes.get('_route') starts with 'app_admin_quiz_' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Questionnaires
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_admin_question_index') }}" class="rounded-sm font-medium {% if app.request.attributes.get('_route') starts with 'app_admin_question_' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Questions
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_admin_response_index') }}" class="rounded-sm font-medium {% if app.request.attributes.get('_route') starts with 'app_admin_response_' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Réponses
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_admin_stress_threshold_index') }}" class="rounded-sm font-medium mt-2 {% if app.request.attributes.get('_route') starts with 'app_admin_stress_threshold_' %}border-2 border-[#003189] !text-[#003189] bg-transparent font-bold focus:!bg-transparent active:!bg-transparent{% else %}text-base-content/80 hover:bg-base-200 focus:!bg-base-200 active:!bg-base-200 focus:!text-base-content{% endif %}">
                                Seuils de Stress
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </aside>

        {# Main content admin #}
        <div class="flex-grow w-full" data-turbo="false">
            <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm">
                <div class="card-body p-6 md:p-10 !overflow-visible">
                    {% block admin_content %}{% endblock %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
