{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h1 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue tracking-tight">Gestion des Documentations</h1>
        
        {{ include('components/_button.html.twig', {
            label: 'Nouvelle Documentation',
            variant: 'primary',
            attr: 'href="' ~ path('app_admin_documentation_new') ~ '"',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>'
        }) }}
    </div>

    <div class="overflow-x-auto rounded-sm border border-base-200">
        <table class="table table-zebra table-sm md:table-md w-full">
            <thead class="bg-base-200 text-base-content">
                <tr>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Titre</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Catégories</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider">Statut</th>
                    <th class="font-bold text-[0.8rem] uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for doc in pagination %}
                    <tr class="hover">
                        <td>
                            <span class="font-bold text-base-content">{{ doc.title }}</span>
                        </td>
                        <td>
                            <div class="flex flex-wrap gap-1">
                                {% for cat in doc.categories %}
                                    {{ include('components/_badge.html.twig', { label: cat.name, variant: 'neutral', rounded: true }) }}
                                {% else %}
                                    <span class="text-xs text-base-content/50 italic">Aucune</span>
                                {% endfor %}
                            </div>
                        </td>
                        <td>
                            {% if doc.isActive %}
                                {{ include('components/_badge.html.twig', { label: 'Publié', variant: 'success', rounded: true }) }}
                            {% else %}
                                {{ include('components/_badge.html.twig', { label: 'Brouillon', variant: 'neutral', rounded: true }) }}
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <div class="flex justify-end gap-2">
                                <a href="{{ path('app_admin_documentation_edit', {'id': doc.id}) }}" class="btn btn-xs rounded-sm btn-ghost border border-base-300 text-dsfr-blue font-medium">Éditer</a>

                                <form method="post" action="{{ path('app_admin_documentation_toggle_active', {'id': doc.id}) }}" class="inline-block" onsubmit="return confirm('Êtes-vous sûr de vouloir basculer le statut de cette documentation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle_active_doc' ~ doc.id) }}">
                                    <button type="submit" class="btn btn-xs rounded-sm {% if doc.isActive %}btn-warning btn-outline{% else %}btn-success btn-outline{% endif %}" title="{% if doc.isActive %}Dépublier{% else %}Publier{% endif %}">
                                        {% if doc.isActive %}Dépublier{% else %}Publier{% endif %}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="py-12 text-center text-base-content/60 font-medium">
                            Aucune documentation trouvée.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.getTotalItemCount > 0 %}
        <div class="mt-6 flex justify-center">
            {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
        </div>
    {% endif %}
{% endblock %}
