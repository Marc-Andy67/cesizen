{% extends 'base.html.twig' %}

{% block title %}Mon Espace - CESIZen{% endblock %}

{% block body %}
<div class="py-8 md:py-12 max-w-7xl mx-auto space-y-8 animate-fade-in">

    {# Header de section #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b-2 border-dsfr-blue pb-4">
        <div>
            <h1 class="text-3xl md:text-4xl font-extrabold text-dsfr-blue tracking-tight">Mon Espace Personnel</h1>
            <p class="text-base-content/70 mt-2 font-medium">Gérez vos informations personnelles, vos préférences et consultez l'historique de vos diagnostics.</p>
        </div>
        <div class="hidden md:block">
            <svg class="w-12 h-12 text-dsfr-blue-light opacity-50" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        {# COLONNE PRINCIPALE : Historique #}
        <div class="lg:col-span-2 space-y-8">
            <section aria-labelledby="historique-title">
                <h2 id="historique-title" class="text-2xl font-bold text-dsfr-blue mb-6">Mon historique d'évaluation</h2>
                
                {% if assessments is not empty %}
                    <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm overflow-hidden">
                        <div class="card-body p-6">
                            
                            <div class="relative h-64 md:h-80 w-full mb-8">
                                <canvas id="stressHistoryChart" aria-label="Graphique d'évolution du niveau de stress" role="img"></canvas>
                            </div>
                            
                            <div class="overflow-x-auto">
                                <table class="table table-zebra w-full rounded-sm">
                                    <caption class="sr-only">Historique détaillé de mes tests de stress</caption>
                                    <thead class="bg-base-200 text-base-content">
                                        <tr>
                                            <th scope="col" class="py-3 px-4 font-bold uppercase text-xs">Date</th>
                                            <th scope="col" class="py-3 px-4 font-bold uppercase text-xs hidden sm:table-cell">Test</th>
                                            <th scope="col" class="py-3 px-4 font-bold uppercase text-xs">Score LCU</th>
                                            <th scope="col" class="py-3 px-4 font-bold uppercase text-xs text-right">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for assessment in assessments %}
                                            <tr class="hover">
                                                <td class="px-4 py-3 font-medium">{{ assessment.date|date('d/m/Y') }}</td>
                                                <td class="px-4 py-3 text-base-content/70 hidden sm:table-cell">{{ assessment.quiz.title }}</td>
                                                <td class="px-4 py-3 font-bold text-dsfr-blue text-lg">{{ assessment.totalScore }}</td>
                                                <td class="px-4 py-3 text-right">
                                                    <a href="{{ path('app_diagnostic_result', {'id': assessment.id}) }}" class="btn btn-sm btn-outline text-dsfr-blue hover:bg-dsfr-blue transition-colors focus-visible:ring-2 focus-visible:ring-dsfr-blue outline-none border-dsfr-blue rounded-sm" aria-label="Consulter les détails du diagnostic du {{ assessment.date|date('d/m/Y') }}">Consulter</a>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                {% else %}
                    {{ include('components/_empty_state.html.twig', {
                        title: 'Aucun diagnostic trouvé',
                        message: "Vous n'avez passé aucun test de diagnostic pour le moment.",
                        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
                        action_label: 'Faire mon premier test',
                        action_url: path('app_diagnostic_index')
                    }) }}
                {% endif %}
            </section>
        </div>

        {# COLONNE SECONDAIRE : Paramètres #}
        <div class="space-y-8">
            <section aria-labelledby="infos-title">
                <h2 id="infos-title" class="text-xl font-bold text-dsfr-blue border-b border-base-200 pb-2 mb-4">Mes informations</h2>
                
                <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm">
                    <div class="card-body p-6">
                        {{ form_start(profileForm, {'attr': {'class': 'flex flex-col gap-4'}}) }}
                            
                            <div class="form-control w-full">
                                {{ form_label(profileForm.name, 'Nom ou pseudo (affiché)', {'label_attr': {'class': 'label pb-1 cursor-pointer font-bold'}}) }}
                                {{ form_widget(profileForm.name, {'attr': {'class': 'input input-bordered w-full border-base-300 focus:outline-none focus:border-dsfr-blue-light focus:ring-2 focus:ring-dsfr-blue-light/50 transition-shadow rounded-sm'}}) }}
                                <div class="text-sm text-dsfr-red mt-1 font-medium">{{ form_errors(profileForm.name) }}</div>
                            </div>

                            <div class="form-control w-full">
                                {{ form_label(profileForm.email, 'Adresse de contact', {'label_attr': {'class': 'label pb-1 cursor-pointer font-bold'}}) }}
                                {{ form_widget(profileForm.email, {'attr': {'class': 'input input-bordered w-full border-base-300 focus:outline-none focus:border-dsfr-blue-light focus:ring-2 focus:ring-dsfr-blue-light/50 transition-shadow rounded-sm'}}) }}
                                <div class="text-sm text-dsfr-red mt-1 font-medium">{{ form_errors(profileForm.email) }}</div>
                            </div>

                            <div class="mt-2 text-right">
                                {{ include('components/_button.html.twig', {
                                    label: 'Mettre à jour',
                                    variant: 'primary',
                                    extra_classes: 'w-full md:w-auto'
                                }) }}
                            </div>
                        {{ form_end(profileForm) }}
                    </div>
                </div>
            </section>

            <section aria-labelledby="settings-title">
                <h2 id="settings-title" class="text-xl font-bold text-dsfr-blue border-b border-base-200 pb-2 mb-4">Paramètres et Sécurité</h2>
                
                <div class="space-y-4">
                    
                    {# RGPD Export #}
                    <div class="bg-blue-50 border-l-4 border-dsfr-blue p-4 rounded-r-sm shadow-sm flex flex-col items-start gap-2">
                         <div class="flex items-center gap-2 text-dsfr-blue font-bold">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            <h3>Mes données (RGPD)</h3>
                        </div>
                        <p class="text-sm text-dsfr-blue font-medium mb-2">Téléchargez l'ensemble de vos données d'utilisation personnelles (format JSON).</p>
                        
                        {{ include('components/_button.html.twig', {
                            label: "Télécharger l'archive",
                            variant: 'outline',
                            size: 'sm',
                            attr: 'href="' ~ path('app_profile_export_data') ~ '"'
                        }) }}
                    </div>
                    
                    {# Password reset #}
                    <div class="bg-base-100 border border-base-200 p-4 rounded-sm shadow-sm">
                        <h3 class="font-bold text-base-content mb-1">Authentification</h3>
                        <p class="text-sm text-base-content/70 mb-4">Modifier mon mot de passe via l'envoi d'un courriel.</p>
                        
                        <a href="{{ path('app_forgot_password_request') }}" class="btn btn-sm btn-neutral bg-white text-base-content hover:bg-base-200 border-base-300 font-bold transition-colors focus-visible:ring-2 focus-visible:ring-dsfr-blue outline-none rounded-sm w-full md:w-auto">
                            Changer mon mot de passe
                        </a>
                    </div>
                    
                    {# Danger Zone #}
                    <div class="bg-red-50 border-l-4 border-dsfr-red p-4 rounded-r-sm shadow-sm flex flex-col items-start gap-2 mt-8">
                         <div class="flex items-center gap-2 text-dsfr-red font-bold">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            <h3>Zone de danger</h3>
                        </div>
                        <p class="text-sm text-dsfr-red font-medium mb-3">
                            <span class="font-bold underline">Attention :</span> La suppression de compte est irréversible. Vos données personnelles seront anonymisées pour la recherche.
                        </p>
                        
                        <form method="post" action="{{ path('app_profile_delete') }}" onsubmit="return confirm('Êtes-vous absolument certain(e) de vouloir supprimer définitivement votre compte ? Cette action est irréversible et vos données associées seront anonymisées.');" class="w-full">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                            {{ include('components/_button.html.twig', {
                                label: 'Supprimer définitivement',
                                variant: 'danger',
                                size: 'sm',
                                extra_classes: 'w-full md:w-auto'
                            }) }}
                        </form>
                    </div>

                </div>
            </section>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    {% if assessments is not empty %}
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const ctx = document.getElementById('stressHistoryChart').getContext('2d');
                
                const labels = {{ chartDates|raw }};
                const dataPoints = {{ chartScores|raw }};
                
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Score LCU (Niveau de Stress)',
                            data: dataPoints,
                            borderColor: '#003189', // dsfr-blue
                            backgroundColor: 'rgba(0, 49, 137, 0.1)',
                            borderWidth: 3,
                            pointBackgroundColor: '#003189',
                            pointBorderColor: '#ffffff',
                            pointHoverBackgroundColor: '#ffffff',
                            pointHoverBorderColor: '#003189',
                            pointRadius: 5,
                            pointHoverRadius: 7,
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top',
                            },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                backgroundColor: 'rgba(255, 255, 255, 0.9)',
                                titleColor: '#1f2937',
                                bodyColor: '#1f2937',
                                borderColor: '#e5e7eb',
                                borderWidth: 1
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Score LCU'
                                },
                                // On peut ajouter des lignes de référence pour les seuils si on les connaît
                                // Dans un monde idéal on les passe via le contrôleur, ou on laisse Chart.js gérer
                            },
                            x: {
                                title: {
                                    display: true,
                                    text: 'Date d\'évaluation'
                                }
                            }
                        },
                        interaction: {
                            mode: 'nearest',
                            axis: 'x',
                            intersect: false
                        }
                    }
                });
            });
        </script>
    {% endif %}
{% endblock %}
{% endblock %}
