{% extends 'base.html.twig' %}

{% block title %}Questionnaires Santé & Évaluation - CESIZen{% endblock %}

{% block body %}
<div class="py-8 md:py-12 max-w-6xl mx-auto px-4 space-y-8 animate-fade-in">

    {# HEADER #}
    <div class="text-center mb-12">
        <h1 class="text-3xl md:text-5xl font-extrabold text-dsfr-blue tracking-tight mb-4">Évaluez votre santé mentale</h1>
        <p class="text-lg md:text-xl text-base-content/80 font-medium max-w-3xl mx-auto">Parcourez nos différents questionnaires d'auto-évaluation pour mieux comprendre votre niveau de stress, d'anxiété ou votre équilibre de vie.</p>
    </div>

    {# GRID DES QUESTIONNAIRES #}
    <div class="{% if quizzes|length == 1 %}max-w-md mx-auto{% else %}grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6{% endif %}">
        {% for quiz in quizzes %}
            
            {% set footerButton %}
                {{ include('components/_button.html.twig', {
                    label: 'Démarrer le test',
                    variant: 'primary',
                    attr: 'href="' ~ path('app_diagnostic_take', {'id': quiz.id}) ~ '"',
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>'
                }) }}
            {% endset %}
            
            {% set categoriesList %}
                <div class="flex flex-wrap gap-2 mt-4">
                    {% for category in quiz.categories %}
                        {{ include('components/_badge.html.twig', {
                            label: category.name,
                            variant: 'info'
                        }) }}
                    {% endfor %}
                </div>
            {% endset %}

            {{ include('components/_card.html.twig', {
                title: quiz.title,
                content: quiz.description|nl2br|slice(0, 150) ~ '...',
                footer: categoriesList ~ '<div class="mt-6">' ~ footerButton ~ '</div>',
                shadow: 'md',
                border: true
            }) }}
        {% else %}
            {# Empty State #}
            <div class="col-span-full">
                <div class="card bg-base-100 shadow-sm border border-base-200">
                    <div class="card-body p-6 md:p-10 text-center">
                        <div class="mb-6 flex justify-center text-base-content/40">
                            <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-dsfr-blue mb-4">Aucun questionnaire disponible</h2>
                        <p class="text-base-content/80 font-medium">Revenez plus tard pour découvrir nos nouveaux tests d'auto-évaluation.</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="mt-12 text-center max-w-2xl mx-auto">
        {{ include('components/_alert.html.twig', {
            message: "<strong>Note importante :</strong> Nos questionnaires sont des outils d'auto-évaluation à titre indicatif. Ils ne remplacent en aucun cas un diagnostic ou un avis médical professionnel fourni par un praticien (médecin, psychologue...).",
            type: 'info'
        }) }}
    </div>

</div>
{% endblock %}
