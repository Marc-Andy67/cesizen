{#
    Composant Breadcrumb (Fil d'Ariane) DSFR / DaisyUI
    
    Variables :
    - items (array) : Tableau d'objets ou tableaux associatifs. 
                      Ex: [{ label: 'Accueil', url: path('app_home') }, { label: 'Titre de la page' }]
#}

{% if items is defined and items|length > 0 %}
<nav aria-label="Vous êtes ici :" class="text-sm text-base-content/70 mt-4 mb-6" data-component="breadcrumb">
    <div class="breadcrumbs">
        <ul class="flex flex-wrap items-center">
            {% for item in items %}
                <li class="flex items-center">
                    {% if not loop.last and item.url is defined and item.url %}
                        <a href="{{ item.url }}" class="hover:underline focus-visible:ring-2 focus-visible:ring-dsfr-blue-light outline-none rounded-sm transition-all duration-200">
                            {{ item.label }}
                        </a>
                    {% else %}
                        <span class="font-bold text-base-content" aria-current="page">{{ item.label }}</span>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>
</nav>
{% endif %}
