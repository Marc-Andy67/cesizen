{% extends 'base.html.twig' %}

{% block title %}Vidéos & Documentations - CESIZen{% endblock %}

{% block body %}
<div class="py-8 md:py-12 max-w-7xl mx-auto space-y-10 animate-fade-in">

    {# HEADER SECTION #}
    <div class="text-center max-w-3xl mx-auto mb-12">
        <h1 class="text-3xl md:text-5xl font-extrabold text-dsfr-blue mb-4 tracking-tight">Ressources & Prévention</h1>
        <p class="text-lg md:text-xl text-base-content/70 font-medium">Stress, anxiété, burn-out, troubles du sommeil... Nos ressources sont rédigées par des professionnels de santé pour vous accompagner à chaque étape. Prenez soin de vous, vous le méritez.</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 items-start">
        
        {# FILTRES PAR CATÉGORIE (SIDEBAR) #}
        <aside class="w-full lg:w-72 flex-shrink-0">
            <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm sticky top-8">
                <div class="card-body p-4 sm:p-6">
                    <h2 class="font-bold text-lg text-dsfr-blue mb-4 border-b-2 border-base-200 pb-2 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
                        Catégories
                    </h2>
                    
                    <form action="{{ path('app_documentation_index') }}" method="GET" class="flex flex-col gap-4">
                        <div class="space-y-3">
                            {% for category in categories %}
                                <label class="flex items-start gap-3 cursor-pointer group">
                                    <input type="checkbox" 
                                           name="categories[]" 
                                           value="{{ category.id }}"
                                           {% if current_categories and category.id in current_categories %}checked{% endif %}
                                           class="checkbox checkbox-sm checkbox-primary rounded-sm border-base-300 mt-0.5 [--chkbg:theme(colors.dsfr-blue)] [--chkfg:white] group-hover:border-dsfr-blue transition-colors" />
                                    <span class="text-sm font-medium text-base-content/90 group-hover:text-dsfr-blue transition-colors">{{ category.name }}</span>
                                </label>
                            {% endfor %}
                        </div>

                        <div class="mt-4 pt-4 border-t border-base-200 flex flex-col gap-2">
                            {{ include('components/_button.html.twig', {
                                label: 'Filtrer les résultats',
                                variant: 'primary',
                                size: 'sm',
                                extra_classes: 'w-full'
                            }) }}
                            
                            {% if current_categories is not empty %}
                                <a href="{{ path('app_documentation_index') }}" class="btn btn-sm btn-ghost text-base-content/70 hover:text-dsfr-red focus-visible:ring-2 focus-visible:ring-dsfr-red outline-none rounded-sm w-full font-medium transition-colors">
                                    Réinitialiser
                                </a>
                            {% endif %}
                        </div>
                    </form>
                </div>
            </div>
        </aside>

        {# LISTE DES DOCUMENTATIONS (MAIN GRID) #}
        <div class="flex-grow w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {% for doc in pagination %}
                    
                    {% set doc_badges = [] %}
                    {% for cat in doc.categories %}
                        {% set doc_badges = doc_badges|merge([{'label': cat.name, 'variant': 'info'}]) %}
                    {% endfor %}
                    
                    {# Utilisation du composant _card #}
                    {{ include('components/_card.html.twig', {
                        title: doc.title,
                        badges: doc_badges,
                        content: doc.content|striptags|slice(0, 150) ~ '...',
                        clickable_url: path('app_documentation_show', {'id': doc.id}),
                        footer: include('components/_button.html.twig', {
                            label: "Lire l'article",
                            variant: 'outline',
                            size: 'sm',
                            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />',
                            attr: 'href="' ~ path('app_documentation_show', {'id': doc.id}) ~ '"'
                        })
                    }) }}
                    
                {% else %}
                    <div class="col-span-full">
                        {{ include('components/_empty_state.html.twig', {
                            title: 'Aucune documentation trouvée',
                            message: "Il n'y a pas d'articles disponibles dans cette catégorie pour le moment.",
                            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />',
                            action_label: 'Voir toutes les catégories',
                            action_url: path('app_documentation_index')
                        }) }}
                    </div>
                {% endfor %}
            </div>

            {# Paginator #}
            {% if pagination.getTotalItemCount > 0 %}
                <div class="mt-12 flex justify-center">
                    {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
                </div>
            {% endif %}
            
        </div>
    </div>
</div>
{% endblock %}
