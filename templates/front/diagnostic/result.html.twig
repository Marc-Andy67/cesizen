{% extends 'base.html.twig' %}

{% block title %}Résultat de votre diagnostic - CESIZen{% endblock %}

{% block body %}
<div class="py-8 md:py-12 max-w-4xl mx-auto space-y-8 animate-fade-in">

    {# EN-TÊTE #}
    <div class="text-center mb-8">
        <h1 class="text-3xl md:text-5xl font-extrabold text-dsfr-blue tracking-tight mb-2">Résultat de l'évaluation</h1>
        <p class="text-lg text-base-content/70 font-medium">Basé sur l'échelle de "{{ quiz_title }}" réalisé le {{ date|date('d/m/Y') }}.</p>
        
        {% if is_anonymous %}
            <div class="mt-6 inline-flex max-w-xl text-left">
                {{ include('components/_alert.html.twig', {
                    message: "Vous n'êtes pas connecté. Ce résultat a bien été calculé mais ne pourra pas être sauvegardé dans votre historique personnel.",
                    type: 'warning'
                }) }}
            </div>
        {% endif %}
    </div>

    {# CARTE CENTRALE #}
    <div class="card bg-base-100 shadow-sm border border-base-200 rounded-sm overflow-hidden mb-8">
        
        {# SCORE #}
        <div class="p-8 md:p-12 text-center border-b border-base-200 bg-base-200/50">
            <p class="text-sm font-bold text-base-content/60 uppercase tracking-widest mb-2">Votre Score LCU</p>
            
            <div class="text-6xl md:text-8xl font-black text-dsfr-blue tracking-tighter">
                {{ score }}
            </div>
            
            <p class="text-sm text-base-content/60 mt-2 font-medium">Life Change Units (Unités de Changement de Vie)</p>
        </div>

        {# RÉSULTAT ET SEUIL #}
        {% if threshold %}
            <div class="p-8 md:p-12">
                <h2 class="text-2xl md:text-3xl font-extrabold text-dsfr-blue mb-6 text-center">{{ threshold.name }}</h2>
                
                <div class="prose prose-lg max-w-none text-base-content/80 font-medium mb-8">
                    {{ threshold.description|nl2br }}
                </div>

                <div class="bg-blue-50 border-l-4 border-dsfr-blue p-6 md:p-8 rounded-r-sm shadow-sm">
                    <h3 class="text-xl font-bold text-dsfr-blue mb-4 flex items-center">
                        <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                        Recommandations
                    </h3>
                    <div class="text-dsfr-blue text-lg font-medium leading-relaxed">
                        {{ threshold.advice|nl2br }}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="p-12 text-center text-base-content/60 font-medium">
                Impossible de déterminer un profil pour ce score. Veuillez contacter l'administration.
            </div>
        {% endif %}
    </div>

    {# ACTIONS #}
    <div class="flex flex-col sm:flex-row justify-center gap-4 mt-8">
        {% if is_anonymous %}
            {{ include('components/_button.html.twig', {
                label: 'Créer un compte pour sauvegarder',
                variant: 'primary',
                attr: 'href="' ~ path('app_register') ~ '"'
            }) }}
        {% else %}
            {{ include('components/_button.html.twig', {
                label: 'Mon historique',
                variant: 'secondary',
                attr: 'href="' ~ path('app_profile_index') ~ '"'
            }) }}
        {% endif %}
        
        {{ include('components/_button.html.twig', {
            label: 'Voir les ressources adaptées',
            variant: 'outline',
            attr: 'href="' ~ path('app_documentation_index') ~ '"'
        }) }}
    </div>
</div>
{% endblock %}
