{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h1 class="text-3xl font-bold text-gray-800">Gestion des Utilisateurs</h1>
        
        {# Formulaire de recherche #}
        <form method="get" class="flex w-full md:w-auto">
            <input type="text" name="q" value="{{ search_query }}" placeholder="Rechercher (nom, email)..." 
                   class="px-4 py-2 border border-gray-300 rounded-l-md focus:ring-green-500 focus:border-green-500 flex-grow"
                   aria-label="Recherche utilisateur">
            <button type="submit" class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded-r-md transition-colors">
                Rechercher
            </button>
            {% if search_query %}
                <a href="{{ path('app_admin_user_index') }}" class="ml-2 text-gray-500 hover:text-gray-700 p-2" aria-label="Effacer la recherche">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </a>
            {% endif %}
        </form>
    </div>

    <div class="overflow-x-auto bg-white rounded-lg shadow min-h-[400px]">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Utilisateur</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Inscription</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Statut</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rôle</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                {% for user in pagination %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex flex-col">
                                <span class="font-medium text-gray-900">{{ user.name }}</span>
                                <span class="text-sm text-gray-500">{{ user.email }}</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            {{ user.creationDate|date('d/m/Y') }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            {% if user.isActive %}
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Actif</span>
                            {% else %}
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Inactif</span>
                            {% endif %}
                            
                            {% if user.lockedUntil and user.lockedUntil > date() %}
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800 mt-1">Verrouillé</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="text-purple-700 font-medium">Administrateur</span>
                            {% else %}
                                Utilisateur
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <div class="flex justify-end gap-2">
                                {# Toggle Active #}
                                {% if app.user != user %}
                                    <form method="post" action="{{ path('app_admin_user_toggle_active', {'id': user.id}) }}" class="inline-block" onsubmit="return confirm('Êtes-vous sûr de vouloir {% if user.isActive %}désactiver{% else %}activer{% endif %} ce compte ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_active' ~ user.id) }}">
                                        <button type="submit" class="text-{{ user.isActive ? 'red' : 'green' }}-600 hover:text-{{ user.isActive ? 'red' : 'green' }}-900 bg-{{ user.isActive ? 'red' : 'green' }}-50 px-3 py-1 rounded transition-colors" title="{% if user.isActive %}Désactiver{% else %}Activer{% endif %}">
                                            {% if user.isActive %}Désactiver{% else %}Activer{% endif %}
                                        </button>
                                    </form>
                                
                                    {# Toggle Admin Role #}
                                    <form method="post" action="{{ path('app_admin_user_toggle_role', {'id': user.id}) }}" class="inline-block" onsubmit="return confirm('Êtes-vous sûr de vouloir {% if 'ROLE_ADMIN' in user.roles %}retirer les droits administrateur de{% else %}promouvoir administrateur{% endif %} cet utilisateur ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_role' ~ user.id) }}">
                                        <button type="submit" class="text-purple-600 hover:text-purple-900 bg-purple-50 px-3 py-1 rounded transition-colors" title="{% if 'ROLE_ADMIN' in user.roles %}Retirer Admin{% else %}Rendre Admin{% endif %}">
                                            {% if 'ROLE_ADMIN' in user.roles %}Rétrograder{% else %}Promouvoir{% endif %}
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                            Aucun utilisateur trouvé.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination KnpPaginatorBundle #}
    <div class="mt-4">
        {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
    </div>
{% endblock %}
