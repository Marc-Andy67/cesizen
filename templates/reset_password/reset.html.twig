{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mon mot de passe - CESIZen{% endblock %}

{% block body %}
<div class="flex justify-center items-center py-12 md:py-20 animate-fade-in">
    <div class="card bg-base-100 shadow-sm border border-base-200 w-full max-w-lg rounded-sm">
        <div class="card-body p-8 sm:p-10">
            
            <h1 class="text-3xl font-extrabold text-dsfr-blue mb-2 tracking-tight">Nouveau mot de passe</h1>
            <p class="text-base-content/70 mb-8 font-medium">Veuillez saisir votre nouveau mot de passe ci-dessous.</p>

            {{ form_start(resetForm, {'attr': {'class': 'flex flex-col gap-5'}}) }}
                
                <div class="form-control w-full">
                    {{ form_label(resetForm.plainPassword, 'Nouveau mot de passe', {'label_attr': {'class': 'label pb-1'}}) }}
                    {{ form_widget(resetForm.plainPassword, {'attr': {'class': 'input input-bordered w-full border-base-300 focus:outline-none focus:border-dsfr-blue-light focus:ring-2 focus:ring-dsfr-blue-light/50 transition-shadow rounded-sm'}}) }}
                    <div class="text-sm text-dsfr-red mt-1 font-medium">{{ form_errors(resetForm.plainPassword) }}</div>
                </div>

                <div class="mt-4 pt-4 border-t border-base-200">
                     <button type="submit" class="btn btn-primary w-full text-white hover:bg-dsfr-blue-light border-none font-bold rounded-sm transition-all duration-200 focus-visible:ring-2 focus-visible:ring-dsfr-blue-light focus-visible:ring-offset-2 outline-none">
                        Enregistrer
                    </button>
                </div>
            {{ form_end(resetForm) }}
            
        </div>
    </div>
</div>
{% endblock %}
